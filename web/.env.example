# WebSocket URL of the Go backend.
#
# Leave UNSET for local dev (docker compose + Vite proxy). The client falls back
# to wss?://<current-host>/ws and Vite's dev server proxies /ws to the
# backend container via BACKEND_HOST.
#
# Set in Vercel project settings for production:
#   VITE_WS_URL=wss://your-app.up.railway.app/ws
#
# Note: this is a Vite build-time variable; changing it requires a redeploy.
# VITE_WS_URL=
